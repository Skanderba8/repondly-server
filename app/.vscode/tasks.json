{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Check: TypeScript whole repo",
      "type": "npm",
      "script": "typecheck",
      "problemMatcher": "$tsc",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Check: ESLint whole repo",
      "type": "npm",
      "script": "lint:repo",
      "problemMatcher": "$eslint-stylish",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Check: Full repo",
      "type": "npm",
      "script": "check",
      "problemMatcher": ["$tsc", "$eslint-stylish"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Check: Full repo + build",
      "type": "npm",
      "script": "check:build",
      "problemMatcher": ["$tsc", "$eslint-stylish"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
