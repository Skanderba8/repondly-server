generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// BUSINESS
// The core tenant. One business = one Repondly account.

model Business {
  id         String     @id @default(cuid())
  authUserId String?    @unique
  name       String
  phone      String     @unique
  email      String?    @unique
  slug       String     @unique
  plan       Plan       @default(ESSENTIEL)
  planStatus PlanStatus @default(ACTIVE)
  trialEndsAt DateTime?
  isPaid     Boolean    @default(false)
  onboardingCompletedAt DateTime?

  businessType String?
  tone         String?
  language     Language  @default(FRENCH)
  timezone     String    @default("Africa/Tunis")
  botEnabled            Boolean @default(false)
  botName               String?
  botLanguage           String?
  botMode               String?
  botWorkingHoursStart  String?
  botWorkingHoursEnd    String?
  botKnowledge          String?
  botHandoffKeywords    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images             BusinessImage[]
  channelConnections BusinessChannelConnection[]
  contacts           Contact[]
  conversations      Conversation[]
  messages           Message[]
  notifications      Notification[]
  orders             Order[]
  products           Product[]
  webhookEvents      WebhookEvent[]
}

model BusinessImage {
  id         String   @id @default(cuid())
  businessId String
  category   String
  dataUrl    String   @db.Text
  mimeType   String
  sizeBytes  Int
  position   Int
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, category, position])
}

model BusinessChannelConnection {
  id                     String           @id @default(cuid())
  businessId             String
  channel                ChannelType
  status                 ConnectionStatus @default(PENDING)
  label                  String?
  unipileAccountId       String?          @unique
  unipileAccountType     String?
  displayName            String?
  accessToken            String?
  metadata               Json?
  lastSyncedAt           DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  business      Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
  webhookEvents WebhookEvent[]

  @@index([businessId, channel, status])
}

model Contact {
  id                 String   @id @default(cuid())
  businessId         String
  connectionId       String
  channel            ChannelType
  externalId         String
  name               String?
  username           String?
  phone              String?
  avatarUrl          String?
  notes              String?
  lastSeen           DateTime?
  totalConversations Int      @default(0)
  tags               String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  business      Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connection    BusinessChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  orders        Order[]

  @@unique([businessId, channel, externalId])
  @@index([businessId, connectionId])
}

model Conversation {
  id                   String             @id @default(cuid())
  businessId           String
  connectionId         String
  channel              ChannelType
  contactId            String
  status               ConversationStatus @default(NEW)
  intent               String?
  needsFollowUp        Boolean            @default(false)
  followUpAt           DateTime?
  followUpNote         String?
  unreadCount          Int                @default(0)
  lastMessageAt        DateTime?
  lastInboundMessageAt DateTime?
  lastOutboundMessageAt DateTime?
  firstReplyAt         DateTime?
  resolvedAt           DateTime?
  externalThreadId     String?
  summary              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  business   Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connection BusinessChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  contact    Contact                   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@index([businessId, status])
  @@index([businessId, lastMessageAt])
  @@index([businessId, needsFollowUp])
  @@index([businessId, channel, connectionId, status])
}

model Message {
  id                String        @id @default(cuid())
  businessId        String
  connectionId      String
  channel           ChannelType
  conversationId    String
  direction         Direction
  senderType        SenderType
  type              MessageType   @default(TEXT)
  content           String
  mediaUrl          String?
  mediaType         String?
  externalMessageId String?
  status            MessageStatus @default(SENT)
  externalStatus    String?
  rawPayload        Json?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  replySuggestions  Json?
  createdAt         DateTime @default(now())

  business     Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connection   BusinessChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  conversation Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([businessId, createdAt])
  @@unique([channel, externalMessageId])
  @@index([businessId, channel, connectionId, createdAt])
}

model Notification {
  id         String           @id @default(cuid())
  businessId String
  type       NotificationType
  title      String
  body       String
  data       Json?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, isRead])
  @@index([businessId, createdAt])
}

model WebhookEvent {
  id           String   @id @default(cuid())
  businessId   String?
  connectionId String?
  channel      ChannelType?
  source       String   @default("WHATSAPP")
  eventType    String?
  deliveryId   String?
  headers      Json?
  payload      Json
  processed    Boolean  @default(false)
  error        String?
  processedAt  DateTime?
  createdAt    DateTime @default(now())

  business   Business?                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connection BusinessChannelConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([processed, createdAt])
  @@index([businessId, channel, createdAt])
  @@unique([channel, deliveryId])
}

model Order {
  id              String        @id @default(cuid())
  businessId      String
  contactId       String
  conversationId  String?
  orderNumber     Int
  status          OrderStatus   @default(NOUVEAU)
  paymentStatus   PaymentStatus @default(PAS_ENCORE)
  deliveryMethod  String?
  deliveryAddress String?
  notes           String?
  totalAmount     Decimal       @default(0) @db.Decimal(10,2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact  Contact    @relation(fields: [contactId], references: [id])
  items    OrderItem[]

  @@unique([businessId, orderNumber])
  @@index([businessId, status])
  @@index([businessId, createdAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productName String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10,2)
  totalPrice  Decimal @db.Decimal(10,2)
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(cuid())
  businessId  String
  type        CatalogItemType @default(PRODUCT)
  name        String
  description String?
  price       Decimal  @db.Decimal(10,2)
  deliveryFee Decimal  @default(0) @db.Decimal(10,2)
  stock       Int?
  fournisseur String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  images      ProductImage[]

  @@index([businessId, isActive])
  @@index([businessId, type])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  dataUrl   String   @db.Text
  mimeType  String
  sizeBytes Int
  position  Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

enum CatalogItemType {
  PRODUCT
  SERVICE
}

enum Plan {
  ESSENTIEL
  BUSINESS
  BUSINESS_PLUS
  GROWTH
}

enum PlanStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum Language {
  FRENCH
  ARABIC
  DARIJA
}

enum ChannelType {
  WHATSAPP
  MESSENGER
  INSTAGRAM
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  DISCONNECTED
  ERROR
}

enum ConversationStatus {
  NEW
  IN_PROGRESS
  CONFIRMED
  RESOLVED
  FOLLOW_UP
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum SenderType {
  CUSTOMER
  AGENT
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  REACTION
  SYSTEM
  UNSUPPORTED
}

enum NotificationType {
  NEW_MESSAGE
  FOLLOW_UP_DUE
  DAILY_SUMMARY
  SYSTEM
}

enum OrderStatus {
  NOUVEAU
  CONFIRME
  EN_PREPARATION
  EXPEDIE
  LIVRE
  ANNULE
}

enum PaymentStatus {
  PAS_ENCORE
  ACOMPTE
  RECU
}
