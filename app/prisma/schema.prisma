generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// BUSINESS
// The core tenant. One business = one Repondly account.

model Business {
  id         String     @id @default(cuid())
  authUserId String?    @unique
  name       String
  phone      String     @unique
  email      String?    @unique
  slug       String     @unique
  plan       Plan       @default(TRIAL)
  planStatus PlanStatus @default(ACTIVE)
  trialEndsAt DateTime?
  isPaid     Boolean    @default(false)

  businessType String?
  tone         String?
  language     Language  @default(FRENCH)
  timezone     String    @default("Africa/Tunis")

  waPhoneNumberId String?
  wabaId          String?
  waAccessToken   String?
  waVerifyToken   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
  notifications Notification[]
}

model Contact {
  id           String   @id @default(cuid())
  businessId   String
  waId         String
  name         String?
  phone        String?
  avatarUrl    String?
  notes        String?
  lastSeen     DateTime?
  totalConversations Int @default(0)
  tags         String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([businessId, waId])
  @@index([businessId])
}

model Conversation {
  id           String             @id @default(cuid())
  businessId   String
  contactId    String
  status       ConversationStatus @default(NEW)
  intent       String?
  needsFollowUp Boolean @default(false)
  followUpAt   DateTime?
  followUpNote String?
  lastMessageAt DateTime?
  firstReplyAt DateTime?
  resolvedAt   DateTime?
  summary      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([businessId, status])
  @@index([businessId, lastMessageAt])
  @@index([businessId, needsFollowUp])
}

model Message {
  id             String        @id @default(cuid())
  businessId     String
  conversationId String
  direction      Direction
  senderType     SenderType
  content        String
  mediaUrl       String?
  mediaType      String?
  waMessageId    String?       @unique
  status         MessageStatus @default(SENT)
  replySuggestions Json?
  createdAt      DateTime @default(now())

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([businessId, createdAt])
}

model Notification {
  id         String           @id @default(cuid())
  businessId String
  type       NotificationType
  title      String
  body       String
  data       Json?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, isRead])
  @@index([businessId, createdAt])
}

model WebhookEvent {
  id        String   @id @default(cuid())
  source    String   @default("WHATSAPP")
  payload   Json
  processed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())

  @@index([processed, createdAt])
}

enum Plan {
  TRIAL
  STARTER
  PRO
  AGENCY
}

enum PlanStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum Language {
  FRENCH
  ARABIC
  DARIJA
}

enum ConversationStatus {
  NEW
  IN_PROGRESS
  CONFIRMED
  RESOLVED
  FOLLOW_UP
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum SenderType {
  CUSTOMER
  AGENT
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum NotificationType {
  NEW_MESSAGE
  FOLLOW_UP_DUE
  DAILY_SUMMARY
  SYSTEM
}
