// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id                    String          @id @default(cuid())
  name                  String
  email                 String          @unique
  passwordHash          String
  phone                 String?
  chatwootAccountId     Int?            @unique
  chatwootApiToken      String?
  plan                  Plan            @default(FREE)
  status                String          @default("TRIAL")
  trialEndsAt           DateTime?
  lastLoginAt           DateTime?
  paidThisMonth         Boolean         @default(false)
  paymentMethod         String?
  channels              String[]        @default([])
  businessInfo          Json?

  // WhatsApp Embedded Signup
  // WhatsApp Embedded Signup
  wabaId                String?
  whatsappPhoneNumberId String?
  whatsappInboxId       Int?
  whatsappConnected     Boolean   @default(false)

    // Facebook
  facebookPageId        String?
  facebookPageToken     String?
  facebookInboxId       Int?
  facebookConnected     Boolean   @default(false)

  // Instagram
  instagramAccountId    String?
  instagramInboxId      Int?
  instagramConnected    Boolean   @default(false)

  // New Onboarding Milestones
  hasAcceptedDPA        Boolean   @default(false)
  hasSetBusinessHours   Boolean   @default(false)
  hasConfiguredBot      Boolean   @default(false)

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  clients               Client[]
  autoRules             AutoRule[]
  reminders             Reminder[]
  bookings              Booking[]
  adminNotes            AdminNote[]
  onboarding            OnboardingStage?
  activityLogs          ActivityLog[]
  botEvents             BotEvent[]
  connectedPages        ConnectedPage[]
}

model Client {
  id                String         @id @default(cuid())
  businessId        String
  name              String
  phone             String?
  email             String?
  channel           Channel
  chatwootContactId Int?
  createdAt         DateTime       @default(now())

  business          Business       @relation(fields: [businessId], references: [id])
  reminders         Reminder[]
  bookings          Booking[]
}

model AutoRule {
  id               String   @id @default(cuid())
  businessId       String
  name             String
  trigger          Trigger
  conditions       Json
  action           Action
  responseTemplate String
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business         Business @relation(fields: [businessId], references: [id])
}

model Reminder {
  id          String         @id @default(cuid())
  businessId  String
  clientId    String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  status      ReminderStatus @default(PENDING)
  createdAt   DateTime       @default(now())

  business    Business       @relation(fields: [businessId], references: [id])
  client      Client         @relation(fields: [clientId], references: [id])
}

model Booking {
  id              String        @id @default(cuid())
  businessId      String
  clientId        String
  service         String
  datetime        DateTime
  status          BookingStatus @default(PENDING)
  calendarEventId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business      @relation(fields: [businessId], references: [id])
  client          Client        @relation(fields: [clientId], references: [id])
}

model AdminNote {
  id         String   @id @default(cuid())
  businessId String
  content    String
  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id])
}

model OnboardingStage {
  id         String   @id @default(cuid())
  businessId String   @unique
  stage      String   @default("DEMO_BOOKED")
  updatedAt  DateTime @updatedAt

  business   Business @relation(fields: [businessId], references: [id])
}

model ActivityLog {
  id         String   @id @default(cuid())
  businessId String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id])
}

model BotEvent {
  id          String    @id @default(cuid())
  businessId  String?
  eventType   String
  channel     String?
  message     String?
  ruleMatched String?
  wasHandled  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  business    Business? @relation(fields: [businessId], references: [id])
}

model ConnectedPage {
  id              String   @id @default(cuid())
  businessId      String
  pageId          String
  pageName        String
  pageToken       String
  channel         Channel
  chatwootInboxId Int?
  igAccountId     String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business        Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, pageId, channel])
}

// ---------- Enums ----------

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  EMAIL
}

enum Trigger {
  MESSAGE
  COMMENT
  KEYWORD
}

enum Action {
  REPLY
  REMINDER
  TAG
  ASSIGN
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("ADMIN")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
