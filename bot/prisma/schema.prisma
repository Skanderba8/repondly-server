generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id                    String    @id @default(cuid())
  name                  String
  email                 String    @unique
  passwordHash          String
  phone                 String?
  chatwootAccountId     Int?      @unique
  chatwootApiToken      String?
  plan                  Plan      @default(FREE)
  status                String    @default("TRIAL")
  trialEndsAt           DateTime?
  lastLoginAt           DateTime?
  paidThisMonth         Boolean   @default(false)
  paymentMethod         String?
  channels              String[]  @default([])
  businessInfo          Json?

  // WhatsApp Embedded Signup
  wabaId                String?
  whatsappPhoneNumberId String?
  whatsappInboxId       Int?
  whatsappConnected     Boolean   @default(false)

  // Facebook
  facebookPageId        String?
  facebookPageToken     String?
  facebookInboxId       Int?
  facebookConnected     Boolean   @default(false)

  // Instagram
  instagramAccountId    String?
  instagramInboxId      Int?
  instagramConnected    Boolean   @default(false)

  // New Onboarding Milestones
  hasAcceptedDPA        Boolean   @default(false)
  hasSetBusinessHours   Boolean   @default(false)
  hasConfiguredBot      Boolean   @default(false)

  // AI Bot Configuration
  businessType          BusinessType?
  botMode               BotMode?
  languages             String[]  @default([])
  tone                  String?
  ownerPhone            String?
  chatwootInboxId       Int?
  chatwootAgentId       Int?
  active                Boolean   @default(true)
  repondlyPassword      String?
  description           String?
  botName               String?
  greetingMessage       String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relationships
  clients               Client[]
  autoRules             AutoRule[]
  reminders             Reminder[]
  bookings              Booking[]
  adminNotes            AdminNote[]
  onboarding            OnboardingStage?
  activityLogs          ActivityLog[]
  botEvents             BotEvent[]
  connectedPages        ConnectedPage[]
  conversationStatuses  ConversationStatus[]
  conversationViews     ConversationView[]
  products              Product[]
  services              Service[]
  schedules             Schedule[]
  faqs                  Faq[]
  botConfig             BotConfig?
  conversationLogs      ConversationLog[]
  conversationCRMNotes  ConversationCRMNote[]
}

model Client {
  id                String    @id @default(cuid())
  businessId        String
  name              String
  phone             String?
  email             String?
  channel           Channel
  chatwootContactId Int?
  createdAt         DateTime  @default(now())

  business          Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reminders         Reminder[]
  bookings          Booking[]
}

model AutoRule {
  id               String   @id @default(cuid())
  businessId       String
  name             String
  trigger          Trigger
  conditions       Json
  action           Action
  responseTemplate String
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String         @id @default(cuid())
  businessId  String
  clientId    String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  status      ReminderStatus @default(PENDING)
  createdAt   DateTime       @default(now())

  business    Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Booking {
  id              String        @id @default(cuid())
  businessId      String
  clientId        String
  service         String
  datetime        DateTime
  status          BookingStatus @default(PENDING)
  calendarEventId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model AdminNote {
  id         String   @id @default(cuid())
  businessId String
  content    String
  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model OnboardingStage {
  id         String   @id @default(cuid())
  businessId String   @unique
  stage      String   @default("DEMO_BOOKED")
  updatedAt  DateTime @updatedAt

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         String   @id @default(cuid())
  businessId String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BotEvent {
  id          String   @id @default(cuid())
  businessId  String?
  eventType   String
  channel     String?
  message     String?
  ruleMatched String?
  wasHandled  Boolean  @default(false)
  createdAt   DateTime @default(now())

  business    Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
}

model ConnectedPage {
  id              String   @id @default(cuid())
  businessId      String
  pageId          String
  pageName        String
  pageToken       String
  channel         Channel
  chatwootInboxId Int?
  igAccountId     String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, pageId, channel])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  role         AdminRole @default(ADMIN)
  active       Boolean   @default(true)
  passwordHash String
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ConversationStatus {
  id             String              @id @default(cuid())
  businessId     String
  conversationId Int                 @unique
  status         RepondlyTicketStatus @default(EN_ATTENTE)
  updatedAt      DateTime            @updatedAt

  business       Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, conversationId])
}

model ConversationView {
  id             String   @id @default(cuid())
  businessId     String
  conversationId Int
  lastViewedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, conversationId])
  @@index([businessId, conversationId])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  EMAIL
}

enum Trigger {
  MESSAGE
  COMMENT
  KEYWORD
}

enum Action {
  REPLY
  REMINDER
  TAG
  ASSIGN
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum RepondlyTicketStatus {
  EN_ATTENTE
  RESOLUE
}

// ─── AI Bot Enums ────────────────────────────────────────────────────────────────

enum BusinessType {
  SALON
  RESTAURANT
  BOUTIQUE
  CLINIC
  OTHER
}

enum BotMode {
  ORDERS
  APPOINTMENTS
  BOTH
  INFO_ONLY
}

enum TerminalAction {
  ORDER
  APPOINTMENT
  HANDOVER
}

enum ConversationLogStatus {
  ACTIVE
  RESOLVED
  HANDED_OVER
}

// ─── AI Bot Models ───────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  price       Float
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Service {
  id             String   @id @default(cuid())
  businessId     String
  name           String
  description    String?
  durationMinutes Int
  price          Float
  available      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Schedule {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int      // 0-6 (Sunday-Saturday)
  openTime   String   // HH:MM format
  closeTime  String   // HH:MM format
  closed     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
}

model Faq {
  id         String   @id @default(cuid())
  businessId String
  question   String
  answer     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BotConfig {
  id                       String   @id @default(cuid())
  businessId               String   @unique
  systemPrompt             String?
  requiredOrderFields      String[] @default([])
  requiredAppointmentFields String[] @default([])
  handoverTriggers         String[] @default([])
  collectName              Boolean  @default(false)
  collectPhone             Boolean  @default(false)
  collectLocation          Boolean  @default(false)
  needsRegen               Boolean  @default(true)
  lastGeneratedAt          DateTime?
  strictInstructionBlock   String?
  
  // Language handling
  primaryLanguage          String?
  allowDarijaInput         Boolean  @default(true)
  forceProfessionalArabic Boolean  @default(true)
  
  // Handover configuration
  whatsappPhoneNumberId    String?
  whatsappToken            String?
  
  // Extraction configuration
  enableLiveExtraction     Boolean  @default(true)
  extractionDepth          String   @default("standard")
  
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  business                 Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ConversationLog {
  id              String              @id @default(cuid())
  businessId      String
  chatwootConversationId Int
  status          ConversationLogStatus @default(ACTIVE)
  terminalAction  TerminalAction?
  actionData      Json?
  botEnabled      Boolean             @default(true)
  createdAt       DateTime @default(now())

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ConversationCRMNote {
  id                      String   @id @default(cuid())
  businessId              String
  chatwootConversationId  Int
  
  // Identity fields
  customerName            String?
  customerPhone           String?
  customerEmail           String?
  customerLocation        String?
  preferredLanguage       String?
  
  // Commercial intent
  serviceOfInterest       String?
  budget                  String?
  orderIntent             String?
  urgency                 String?
  purchaseStage           String?
  objections              String[]
  preferences             String[]
  
  // Conversation intelligence
  needsSummary            String?
  importantContext        String?
  painPoints              String[]
  customRequests          String[]
  sentiment               String?
  frustrationLevel        Int?
  
  // Business actions
  appointmentRequested    Boolean  @default(false)
  quoteRequested          Boolean  @default(false)
  orderRequested          Boolean  @default(false)
  supportRequested        Boolean  @default(false)
  followUpNeeded          Boolean  @default(false)
  humanHandoverStatus     String?
  
  // Metadata
  lastExtractedAt         DateTime @default(now())
  extractionCount         Int      @default(0)
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  business                Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  @@unique([businessId, chatwootConversationId])
  @@index([businessId, chatwootConversationId])
}
