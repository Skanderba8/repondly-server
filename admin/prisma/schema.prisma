generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id                 String              @id @default(cuid())
  name               String
  phone              String              @unique
  email              String?             @unique
  slug               String              @unique
  plan               Plan
  planStatus         PlanStatus
  trialEndsAt        DateTime?
  billingCycleAnchor DateTime?
  monthlyPrice       Decimal?
  isPaid             Boolean             @default(false)
  passwordHash       String
  onboardingStage    OnboardingStage
  botEnabled         Boolean             @default(false)
  botLanguage        BotLanguage
  timezone           String              @default("Africa/Tunis")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  businessType       String?
  ownerWhatsapp      String?
  chatwootAccountId  Int?                @unique
  chatwootApiToken   String?
  chatwootAgentId    Int?
  channels           String[]
  activityLogs          ActivityLog[]
  adminNotes            AdminNote[]
  autoRules             AutoRule[]
  bookings              Booking[]
  botConfig             BotConfig?
  botEvents             BotEvent[]
  Broadcast             Broadcast[]
  connectedPages        ConnectedPage[]
  Contact               Contact[]
  Conversation          Conversation[]
  conversationLogs      ConversationLog[]
  conversationStatusRecords ConversationStatus[]
  conversationViews     ConversationView[]
  conversationCRMNotes  ConversationCRMNote[]
  faqs                  Faq[]
  Inbox                 Inbox[]
  messageLogs           MessageLog[]
  messages              Message[]
  Notification          Notification[]
  OAuthState            OAuthState[]
  onboardingProgress    OnboardingProgress?
  orders                Order[]
  products              Product[]
  PushSubscription      PushSubscription[]
  schedules             Schedule[]
  scheduleExceptions    ScheduleException[]
  services              Service[]
  WebhookEvent          WebhookEvent[]
}

model AutoRule {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  triggerKeywords String[]
  replyText       String
  isActive        Boolean  @default(true)
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model AdminNote {
  id         String    @id @default(cuid())
  businessId String
  adminId    String
  content    String
  createdAt  DateTime  @default(now())
  AdminUser  AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BotEvent {
  id             String        @id @default(cuid())
  businessId     String
  conversationId String?
  event          String
  payload        Json?
  createdAt      DateTime      @default(now())
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Conversation   Conversation? @relation(fields: [conversationId], references: [id])

  @@index([businessId, createdAt])
}

model AdminUser {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String
  passwordHash String
  role         AdminRole   @default(ADMIN)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  AdminNote    AdminNote[]
}

model Product {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  price       Decimal?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Service {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  duration    Int?
  price       Decimal?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Schedule {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
}

model Faq {
  id         String   @id @default(cuid())
  businessId String
  question   String
  answer     String
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ScheduleException {
  id         String   @id @default(cuid())
  businessId String
  date       DateTime @db.Date
  isClosed   Boolean  @default(false)
  openTime   String?
  closeTime  String?
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, date])
}

model BotConfig {
  id               String   @id @default(cuid())
  businessId       String   @unique
  systemPrompt     String
  fallbackMessage  String
  handoverMessage  String
  maxTurns         Int      @default(10)
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  enableImages     Boolean  @default(false)
  enableVoice      Boolean  @default(false)
  outsideHoursMode String   @default("voicemail")
  personality      String?
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Order {
  id                     String        @id @default(cuid())
  businessId             String
  type                   String
  status                 String        @default("PENDING")
  clientName             String?
  clientPhone            String?
  items                  Json?
  notes                  String?
  total                  Decimal?
  datetime               DateTime?
  chatwootConversationId String?
  contactId              String?
  conversationId         String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  address                String?
  deliverySlot           String?
  source                 String?
  business               Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Contact                Contact?      @relation(fields: [contactId], references: [id])
  Conversation           Conversation? @relation(fields: [conversationId], references: [id])

  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, type])
}

model BotSession {
  id             String       @id
  conversationId String       @unique
  turns          Int          @default(0)
  lastActivity   DateTime
  context        Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Broadcast {
  id                 String               @id
  businessId         String
  name               String
  content            String
  status             String               @default("draft")
  sentAt             DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  Business           Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  BroadcastRecipient BroadcastRecipient[]

  @@index([businessId, createdAt])
}

model BroadcastRecipient {
  id          String    @id
  broadcastId String
  contactId   String
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  Contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([broadcastId, contactId])
  @@index([broadcastId, status])
}

model Contact {
  id                 String               @id
  businessId         String
  channel            Channel
  externalId         String
  name               String?
  avatarUrl          String?
  phone              String?
  email              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  BroadcastRecipient BroadcastRecipient[]
  Business           Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Conversation       Conversation[]
  Order              Order[]

  @@unique([businessId, channel, externalId])
}

model Conversation {
  id            String             @id
  businessId    String
  inboxId       String
  contactId     String
  status        ConversationStatusEnum
  assignedTo    String?
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime
  BotEvent      BotEvent[]
  BotSession    BotSession?
  Business      Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Contact       Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Inbox         Inbox              @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  Message       Message[]
  Order         Order[]
}

model Inbox {
  id                 String         @id
  businessId         String
  channel            Channel
  name               String
  isActive           Boolean        @default(true)
  phoneNumberId      String?
  wabaId             String?
  accessToken        String
  pageId             String?
  instagramAccountId String?
  webhookVerifyToken String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime
  Conversation       Conversation[]
  Business           Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, channel, phoneNumberId])
}

model Message {
  id             String           @id
  conversationId String
  businessId     String
  direction      MessageDirection
  senderType     SenderType
  content        String
  mediaUrl       String?
  mediaType      String?
  externalId     String?          @unique
  status         MessageStatus
  failureReason  String?
  createdAt      DateTime         @default(now())
  Business       Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Notification {
  id         String   @id
  businessId String
  title      String
  body       String
  data       Json?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([businessId, isRead])
}

model OAuthState {
  id         String   @id
  businessId String
  state      String   @unique
  channel    Channel
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id         String   @id
  businessId String
  endpoint   String
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, endpoint])
  @@index([businessId])
}

model WebhookEvent {
  id         String    @id
  businessId String?
  source     Channel
  payload    Json
  processed  Boolean   @default(false)
  error      String?
  createdAt  DateTime  @default(now())
  Business   Business? @relation(fields: [businessId], references: [id])

  @@index([businessId, createdAt])
}

model ActivityLog {
  id         String    @id @default(cuid())
  businessId String?
  action     String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  Business   Business? @relation(fields: [businessId], references: [id])

  @@index([businessId, createdAt])
}

model ConnectedPage {
  id             String   @id @default(cuid())
  businessId     String
  pageId         String
  pageName       String
  pageToken      String
  channel        String
  chatwootInboxId Int?
  igAccountId    String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, pageId, channel])
  @@index([businessId])
}

model ConversationLog {
  id                   String   @id @default(cuid())
  businessId           String
  chatwootConversationId Int
  status               String?
  botEnabled           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  business             Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, chatwootConversationId])
  @@index([businessId])
}

model Booking {
  id              String   @id @default(cuid())
  businessId      String
  clientId        String
  service         String
  datetime        DateTime
  status          String   @default("PENDING")
  calendarEventId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
  @@index([businessId, createdAt])
}

model OnboardingProgress {
  id        String   @id @default(cuid())
  businessId String  @unique
  stage     String   @default("DEMO_BOOKED")
  updatedAt DateTime @updatedAt
  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model MessageLog {
  id                   String   @id @default(cuid())
  businessId           String
  chatwootConversationId Int
  content              String?
  senderType           String
  createdAt            DateTime @default(now())
  business             Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([businessId, chatwootConversationId])
}

model ConversationStatus {
  id             String   @id @default(cuid())
  businessId     String
  conversationId Int
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([conversationId])
  @@index([businessId])
}

model ConversationView {
  id             String   @id @default(cuid())
  businessId     String
  conversationId Int
  lastViewedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, conversationId])
  @@index([businessId])
}

model ConversationCRMNote {
  id                   String   @id @default(cuid())
  businessId           String
  chatwootConversationId Int
  customerName         String?
  customerPhone        String?
  customerEmail        String?
  customerLocation     String?
  preferredLanguage    String?
  serviceOfInterest    String?
  budget               String?
  orderIntent          String?
  urgency              String?
  purchaseStage        String?
  objections           String[] @default([])
  preferences          String[] @default([])
  needsSummary         String?
  importantContext     String?
  painPoints           String[] @default([])
  customRequests       String[] @default([])
  sentiment            String?
  frustrationLevel     Int?
  appointmentRequested Boolean  @default(false)
  quoteRequested       Boolean  @default(false)
  orderRequested       Boolean  @default(false)
  supportRequested     Boolean  @default(false)
  followUpNeeded       Boolean  @default(false)
  humanHandoverStatus  String?
  lastExtractedAt      DateTime @default(now())
  extractionCount      Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  business             Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, chatwootConversationId])
  @@index([businessId, chatwootConversationId])
}

enum Plan {
  TRIAL
  STARTER
  PRO
  ENTERPRISE
}

enum Channel {
  WHATSAPP
  FACEBOOK
  INSTAGRAM
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum BotLanguage {
  FR
  AR
  DARIJA
}

enum ConversationStatusEnum {
  OPEN
  BOT
  HUMAN
  RESOLVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum OnboardingStage {
  LEAD
  DEMO
  CONTRACT
  SETUP
  LIVE
  CHURNED
}

enum PlanStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum SenderType {
  CUSTOMER
  BOT
  AGENT
}
